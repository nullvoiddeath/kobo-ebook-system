ZLIB_EMAIL=your_email@example.com
ZLIB_PASSWORD=your_password

# Recommended: use remix tokens instead of email/password
# Get these from browser cookies after logging into Z-Library,
# or login once with email/password and check the logs for your tokens
# ZLIB_REMIX_USERID=your_user_id
# ZLIB_REMIX_USERKEY=your_user_key
